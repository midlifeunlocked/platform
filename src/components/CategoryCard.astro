---
/**
 * CategoryCard — image tile with the category name overlaid on a darkened
 * photo and a lock glyph, matching the original site's category row.
 */
import Icon from './Icon.astro';

interface Props {
  name: string;
  count: number;
  image: string;
  href?: string;
  portrait?: boolean;
  [key: string]: unknown;
}

const { name, count, image, href = '#', portrait = false, ...rest } = Astro.props;
---

<a class:list={['cat', { 'cat--portrait': portrait }]} href={href} {...rest}>
  <img class="cat__img" src={image} alt="" loading="lazy" />
  <span class="cat__scrim"></span>
  <span class="cat__lock"><Icon name="lock" size={15} /></span>
  <span class="cat__body">
    <span class="cat__name">{name}</span>
    <span class="cat__count">{count} {count === 1 ? 'lesson' : 'lessons'}</span>
  </span>
</a>

<style>
  .cat {
    position: relative;
    display: block;
    aspect-ratio: 4 / 3;
    color: var(--mu-white);
    background: var(--mu-surface-3);
    border: 1px solid var(--mu-line-soft);
    border-radius: var(--mu-radius-lg);
    overflow: hidden;
    transition: transform var(--mu-dur) var(--mu-ease), border-color var(--mu-dur) var(--mu-ease);
  }
  .cat--portrait { aspect-ratio: 3 / 4; }
  .cat:hover { color: var(--mu-white); transform: translateY(-4px); border-color: var(--mu-bronze); }

  .cat__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--mu-dur-slow) var(--mu-ease);
  }
  .cat:hover .cat__img { transform: scale(1.06); }

  .cat__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(18, 18, 20, 0.1) 25%, rgba(18, 18, 20, 0.55) 60%, rgba(18, 18, 20, 0.92) 100%);
  }

  .cat__lock {
    position: absolute;
    top: var(--mu-space-3);
    left: var(--mu-space-3);
    display: grid;
    place-items: center;
    width: 32px; height: 32px;
    color: var(--mu-bronze-soft);
    background: rgba(18, 18, 20, 0.55);
    backdrop-filter: blur(6px);
    border-radius: var(--mu-radius-pill);
  }

  .cat__body {
    position: absolute;
    left: var(--mu-space-5);
    right: var(--mu-space-4);
    bottom: var(--mu-space-4);
    display: grid;
    gap: 2px;
  }
  .cat__name {
    font-family: var(--mu-font-display);
    font-size: var(--mu-text-xl);
    font-weight: var(--mu-weight-bold);
    letter-spacing: var(--mu-tracking-tight);
    line-height: 1.1;
  }
  .cat__count {
    font-size: var(--mu-text-xs);
    color: var(--mu-fog);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
</style>
