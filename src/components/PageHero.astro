---
/**
 * PageHero — the standard inner-page header: eyebrow, title, intro, and an
 * optional action slot. A subtle bronze glow ties it to the brand without
 * needing a per-page image. Used by all the secondary public pages.
 */
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, intro, align = 'left' } = Astro.props;
const hasActions = Astro.slots.has('default');
---

<section class:list={['page-hero', `page-hero--${align}`]}>
  <div class="mu-container page-hero__inner">
    {eyebrow && <span class="mu-eyebrow" data-reveal>{eyebrow}</span>}
    <h1 class="page-hero__title" data-reveal style="--reveal-delay:80ms">{title}</h1>
    {intro && <p class="page-hero__intro" data-reveal style="--reveal-delay:150ms">{intro}</p>}
    {hasActions && (
      <div class="page-hero__actions" data-reveal style="--reveal-delay:220ms"><slot /></div>
    )}
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    padding-block: clamp(3rem, 6vw, 5rem) clamp(2.5rem, 4vw, 3.5rem);
    border-bottom: 1px solid var(--mu-line-soft);
    background:
      radial-gradient(80% 120% at 100% 0%, rgba(164, 97, 51, 0.12), transparent 55%),
      var(--mu-bg);
  }
  .page-hero__inner { max-width: 760px; }
  .page-hero--center .page-hero__inner { max-width: 720px; margin-inline: auto; text-align: center; }
  .page-hero--center .mu-eyebrow { justify-content: center; }

  .page-hero__title { margin-top: var(--mu-space-4); font-size: var(--mu-text-4xl); line-height: 1.06; }
  .page-hero__intro {
    margin-top: var(--mu-space-5);
    font-size: var(--mu-text-lg);
    color: var(--mu-fog);
    max-width: 60ch;
  }
  .page-hero--center .page-hero__intro { margin-inline: auto; }
  .page-hero__actions { display: flex; flex-wrap: wrap; gap: var(--mu-space-4); margin-top: var(--mu-space-6); }
  .page-hero--center .page-hero__actions { justify-content: center; }
</style>
