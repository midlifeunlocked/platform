---
/**
 * Faq — native <details> accordion. No JS, keyboard-accessible, reduced-motion
 * safe. Shared by the home, pricing, and contact pages.
 */
import Icon from './Icon.astro';

interface Props {
  items: { q: string; a: string }[];
}

const { items } = Astro.props;
---

<div class="faq" data-reveal>
  {items.map((item) => (
    <details class="faq__item">
      <summary class="faq__q">
        {item.q}
        <span class="faq__icon"><Icon name="chevron-down" size={20} /></span>
      </summary>
      <p class="faq__a">{item.a}</p>
    </details>
  ))}
</div>

<style>
  .faq { max-width: 760px; margin-inline: auto; display: grid; gap: var(--mu-space-3); }
  .faq__item {
    background: var(--mu-surface-2);
    border: 1px solid var(--mu-line-soft);
    border-radius: var(--mu-radius);
    padding: 0 var(--mu-space-5);
  }
  .faq__item[open] { border-color: var(--mu-line); }
  .faq__q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--mu-space-4);
    padding: var(--mu-space-5) 0;
    color: var(--mu-white);
    font-family: var(--mu-font-display);
    font-size: var(--mu-text-lg);
    font-weight: var(--mu-weight-bold);
    cursor: pointer;
    list-style: none;
  }
  .faq__q::-webkit-details-marker { display: none; }
  .faq__icon { color: var(--mu-bronze-soft); flex-shrink: 0; transition: transform var(--mu-dur) var(--mu-ease); }
  .faq__item[open] .faq__icon { transform: rotate(180deg); }
  .faq__a {
    margin: 0;
    padding-bottom: var(--mu-space-5);
    color: var(--mu-fog);
    max-width: 62ch;
  }
</style>
