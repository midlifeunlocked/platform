---
/**
 * Footer — brand mark, a short positioning line, navigation columns, and legal.
 * Content mirrors the site's real navigation (Site Navigation from /reference).
 */
const year = new Date().getFullYear();

const columns = [
  {
    title: 'Explore',
    links: [
      { label: 'Categories', href: '/categories' },
      { label: 'Free core lessons', href: '/categories#free' },
      { label: 'Premium lessons', href: '/categories#premium' },
      { label: 'Instructors', href: '/instructors' },
    ],
  },
  {
    title: 'Membership',
    links: [
      { label: 'Pricing', href: '/pricing' },
      { label: 'Start free', href: '/signup' },
      { label: 'Log in', href: '/login' },
      { label: 'Account', href: '/account' },
    ],
  },
  {
    title: 'Company',
    links: [
      { label: 'Contact', href: '/contact' },
      { label: 'Privacy', href: '/privacy' },
      { label: 'Terms', href: '/terms' },
    ],
  },
];
---

<footer class="footer">
  <div class="mu-container mu-container--wide">
    <div class="footer__top">
      <div class="footer__brand">
        <img src="/brand/logo-full-white.png" alt="Midlife Unlocked" class="footer__mark" />
        <p class="footer__tagline">
          Expert-taught masterclasses for divorced men over 40. Go after the life
          you've quietly wanted all along.
        </p>
      </div>

      <nav class="footer__nav" aria-label="Footer">
        {columns.map((col) => (
          <div class="footer__col">
            <h3 class="footer__col-title">{col.title}</h3>
            <ul>
              {col.links.map((l) => (
                <li><a href={l.href}>{l.label}</a></li>
              ))}
            </ul>
          </div>
        ))}
      </nav>
    </div>

    <div class="footer__bottom">
      <p>&copy; {year} Midlife Unlocked. All rights reserved.</p>
      <p class="footer__fineprint">Built for the second chapter.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--mu-ink-2);
    border-top: 1px solid var(--mu-line-soft);
    padding-block: var(--mu-space-9) var(--mu-space-6);
  }
  .footer__top {
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: var(--mu-space-8);
    padding-bottom: var(--mu-space-8);
    border-bottom: 1px solid var(--mu-line-soft);
  }
  .footer__mark { height: 64px; width: auto; margin-bottom: var(--mu-space-4); }
  .footer__tagline { color: var(--mu-mute); max-width: 38ch; font-size: var(--mu-text-sm); }

  .footer__nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--mu-space-6);
  }
  .footer__col-title {
    font-size: var(--mu-text-xs);
    font-weight: var(--mu-weight-bold);
    letter-spacing: var(--mu-tracking-label);
    text-transform: uppercase;
    color: var(--mu-faint);
    margin-bottom: var(--mu-space-4);
  }
  .footer__col ul { display: grid; gap: var(--mu-space-3); }
  .footer__col a {
    color: var(--mu-fog);
    font-size: var(--mu-text-sm);
  }
  .footer__col a:hover { color: var(--mu-amber); }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    gap: var(--mu-space-4);
    padding-top: var(--mu-space-5);
    color: var(--mu-faint);
    font-size: var(--mu-text-xs);
  }

  @media (max-width: 820px) {
    .footer__top { grid-template-columns: 1fr; gap: var(--mu-space-6); }
    .footer__nav { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 520px) {
    .footer__nav { grid-template-columns: 1fr; }
    .footer__bottom { flex-direction: column; }
  }
</style>
