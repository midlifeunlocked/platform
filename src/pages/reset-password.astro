---
import BaseLayout from '@layouts/BaseLayout.astro';
import Button from '@components/Button.astro';
---

<BaseLayout title="Reset password — Midlife Unlocked" description="Reset your Midlife Unlocked account password." noindex>
  <section class="auth">
    <div class="auth__card" data-reveal>
      <a class="auth__brand" href="/"><img src="/brand/logo.png" alt="Midlife Unlocked" height="52" width="52" /></a>
      <h1 class="auth__title">Reset your password</h1>
      <p class="auth__sub">Enter your email and we’ll send you a link to set a new password.</p>

      <form class="auth__form" novalidate>
        <div class="field">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" autocomplete="email" placeholder="you@example.com" required />
        </div>
        <Button type="submit" full size="lg">Send reset link</Button>
      </form>

      <p class="auth__msg" data-msg role="alert" hidden></p>
      <p class="auth__alt">Remembered it? <a href="/login">Back to log in</a>.</p>
    </div>
  </section>

  <script>
    import { sendPasswordReset } from '@/lib/auth';
    const form = document.querySelector<HTMLFormElement>('.auth__form');
    const msg = document.querySelector<HTMLElement>('[data-msg]');
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button');
      const email = (form.querySelector<HTMLInputElement>('#email'))?.value.trim() ?? '';
      if (btn) btn.disabled = true;
      if (msg) { msg.hidden = true; msg.classList.remove('is-ok'); }
      try {
        await sendPasswordReset(email, location.origin + '/update-password');
        if (msg) {
          msg.textContent = 'If that email has an account, a reset link is on its way.';
          msg.classList.add('is-ok');
          msg.hidden = false;
        }
      } catch (err) {
        if (msg) { msg.textContent = (err as Error).message || 'Could not send reset link.'; msg.hidden = false; }
      } finally {
        if (btn) btn.disabled = false;
      }
    });
  </script>
</BaseLayout>

<style>
  .auth { display: grid; place-items: center; padding: clamp(2.5rem, 6vw, 5rem) var(--mu-gutter); }
  .auth__card {
    width: 100%;
    max-width: 440px;
    padding: clamp(1.75rem, 4vw, 2.75rem);
    background: var(--mu-surface-2);
    border: 1px solid var(--mu-line-soft);
    border-radius: var(--mu-radius-lg);
  }
  .auth__brand { display: inline-block; margin-bottom: var(--mu-space-6); }
  .auth__brand img { height: 52px; width: 52px; }
  .auth__title { font-size: var(--mu-text-2xl); }
  .auth__sub { margin-top: var(--mu-space-2); color: var(--mu-mute); }
  .auth__form { display: grid; gap: var(--mu-space-5); margin-top: var(--mu-space-6); }
  .field { display: grid; gap: var(--mu-space-2); }
  .field label { color: var(--mu-white); font-weight: var(--mu-weight-bold); font-size: var(--mu-text-sm); }
  .field input {
    width: 100%;
    padding: var(--mu-space-3) var(--mu-space-4);
    color: var(--mu-white);
    font: inherit;
    background: var(--mu-bg);
    border: 1px solid var(--mu-line);
    border-radius: var(--mu-radius-sm);
    transition: border-color var(--mu-dur) var(--mu-ease);
  }
  .field input::placeholder { color: var(--mu-faint); }
  .field input:focus { outline: none; border-color: var(--mu-bronze); }
  .auth__alt { margin-top: var(--mu-space-5); color: var(--mu-mute); font-size: var(--mu-text-sm); }
  .auth__alt a { color: var(--mu-bronze-soft); font-weight: var(--mu-weight-bold); }
  .auth__msg {
    margin-top: var(--mu-space-4);
    padding: var(--mu-space-3) var(--mu-space-4);
    color: #ffd9c2;
    background: rgba(164, 97, 51, 0.16);
    border: 1px solid var(--mu-bronze);
    border-radius: var(--mu-radius-sm);
    font-size: var(--mu-text-sm);
  }
  .auth__msg.is-ok { color: #cdeccd; background: rgba(46, 120, 64, 0.18); border-color: #2e7840; }
</style>
