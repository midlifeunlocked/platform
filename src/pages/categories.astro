---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/PageHero.astro';
import Section from '@components/Section.astro';
import CategoryCard from '@components/CategoryCard.astro';
import { categories, categoryCount } from '@/data/catalog';
---

<BaseLayout
  title="Browse lessons by category — Midlife Unlocked"
  description="Browse the full Midlife Unlocked catalogue by category — confidence, dating, image, masculinity, body language and business — taught by real experts for men over 40."
>
  <PageHero
    eyebrow="Catalogue"
    title="Browse lessons by category"
    intro="Every masterclass, course, and workshop in one place. Pick a category to dive in."
    align="center"
  />

  <Section>
    <div class="cat-grid">
      {categories.map((c, i) => (
        <CategoryCard
          name={c.name}
          count={categoryCount(c.name)}
          image={c.image}
          href={`/categories/${c.slug}`}
          portrait
          data-reveal
          style={`--reveal-delay:${i * 55}ms`}
        />
      ))}
    </div>
  </Section>
</BaseLayout>
