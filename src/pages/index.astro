---
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/Section.astro';
import Button from '@components/Button.astro';
import Icon from '@components/Icon.astro';
import LessonCard from '@components/LessonCard.astro';
import CategoryCard from '@components/CategoryCard.astro';
import Carousel from '@components/Carousel.astro';
import Faq from '@components/Faq.astro';
import { categories, categoryCount, freeLessons, premiumLessons, toCardProps } from '@/data/catalog';

/* ---------------------------------------------------------------------------
   Homepage — the pristine "Streaming" template's section structure, populated
   with real Midlife Unlocked copy, metadata, and assets (no sample content).
   Catalogue data comes from src/data/catalog.ts; in later phases it comes from
   Supabase, gated through the entitlement layer.
   ------------------------------------------------------------------------- */

const homeFree = freeLessons();
const homePremium = premiumLessons().slice(0, 12);

const planFeatures = [
  'Core and Premium access to every lesson',
  'New masterclasses added every month',
  'Taught by real experts, not influencers',
  'Watch anywhere, cancel anytime',
];

const devices = [
  { icon: 'tv' as const, name: 'Smart TVs', note: 'The big screen' },
  { icon: 'laptop' as const, name: 'Laptops & Computers', note: 'At your desk' },
  { icon: 'phone' as const, name: 'Phones', note: 'In your pocket' },
  { icon: 'tablet' as const, name: 'Tablets', note: 'On the go' },
];

const faqs = [
  {
    q: "What's the difference between Free Core and Premium lessons?",
    a: 'Free Core lessons give you a real taste of the method — no card required. Premium unlocks every full masterclass, with companion workbooks and new lessons added each month.',
  },
  {
    q: 'If I subscribe, do I get access to everything?',
    a: 'Yes. A Premium membership unlocks the entire Midlife Unlocked catalogue — every lesson, course, and workshop — on every device.',
  },
  {
    q: 'Can I cancel at any time?',
    a: 'Anytime, in a couple of clicks from your account. You keep access until the end of your billing period.',
  },
  {
    q: 'Who teaches the masterclasses?',
    a: 'Real, vetted experts in attraction, dating, image, confidence, masculinity and business — not manosphere influencers.',
  },
];
---

<BaseLayout>
  <!-- ===================== HERO — full-bleed brand portrait ===================== -->
  <section class="hero">
    <div class="mu-container hero__inner">
      <div class="hero__copy">
        <span class="mu-eyebrow" data-reveal>Masterclasses for divorced men over 40</span>
        <h1 class="hero__title" data-reveal style="--reveal-delay:90ms">
          Go after the life you've <span class="hero__accent">secretly fantasized</span> about all along.
        </h1>
        <p class="hero__lead" data-reveal style="--reveal-delay:180ms">
          Video lessons, courses, and workshops to help you thrive after divorce —
          actionable, proven, real-world advice built specifically for men over 40.
        </p>

        <ul class="hero__proof" data-reveal style="--reveal-delay:260ms">
          <li><Icon name="check" size={16} /> Learn from top experts: attraction, dating, image, confidence & more</li>
          <li><Icon name="check" size={16} /> Actionable, proven, real-world advice for men over 40</li>
          <li><Icon name="check" size={16} /> New lessons added every month</li>
        </ul>

        <div class="hero__actions" data-reveal style="--reveal-delay:340ms">
          <Button href="/signup" size="lg" icon="arrow-right">Sign up free</Button>
          <Button href="/categories#free" size="lg" variant="ghost" icon="play">Watch a free lesson</Button>
        </div>
        <p class="hero__signin" data-reveal style="--reveal-delay:420ms">Already have an account? <a href="/login">Log in</a>.</p>
      </div>
    </div>
  </section>

  <!-- ===================== EXPLORE LESSON CATEGORIES ===================== -->
  <Section
    title="Explore lesson categories"
    actionLabel="Browse all"
    actionHref="/categories"
  >
    <Carousel variant="cats" label="categories" data-reveal>
      {categories.map((c) => <CategoryCard name={c.name} count={categoryCount(c.name)} image={c.image} href={`/categories#${c.slug}`} />)}
    </Carousel>
  </Section>

  <!-- ===================== FREE CORE LESSONS ===================== -->
  <Section
    id="free"
    tone="inset"
    title="Free core lessons"
    actionLabel="Browse all"
    actionHref="/categories#free"
  >
    <Carousel variant="lessons" label="free lessons" data-reveal>
      {homeFree.map((l) => <LessonCard {...toCardProps(l)} />)}
    </Carousel>
  </Section>

  <!-- ===================== PREMIUM LESSONS ===================== -->
  <Section
    id="premium"
    title="Premium lessons"
    actionLabel="Browse all"
    actionHref="/categories#premium"
  >
    <Carousel variant="lessons" label="premium lessons" data-reveal>
      {homePremium.map((l) => <LessonCard {...toCardProps(l)} />)}
    </Carousel>
  </Section>

  <!-- ===================== PRICING BAND (deep-green surface) ===================== -->
  <section class="plan">
    <div class="mu-container">
      <div class="plan__card" data-reveal>
        <div class="plan__copy">
          <span class="mu-eyebrow"><Icon name="unlock" size={13} /> All-access pass</span>
          <h2 class="plan__title">Thrive after divorce for as little as <span class="plan__price">$14.92</span> per month</h2>
          <p class="plan__sub">
            Grab an all-access pass! Upgrade to the Premium-level membership for as little as
            $14.92 per month, and enjoy every lesson Midlife Unlocked has to offer.
          </p>
          <div class="plan__actions">
            <Button href="/pricing" size="lg" icon="arrow-right">Subscribe today!</Button>
            <Button href="/signup" size="lg" variant="ghost">Start free</Button>
          </div>
        </div>
        <ul class="plan__features">
          {planFeatures.map((f) => (
            <li><span class="plan__check"><Icon name="check" size={15} /></span>{f}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- ===================== AVAILABLE ON YOUR DEVICES ===================== -->
  <Section
    tone="inset"
    eyebrow="Watch anywhere"
    title="Available on all your devices"
    intro="Pick up right where you left off — at home, at the gym, or on the move."
    centered
  >
    <div class="device-grid">
      {devices.map((d, i) => (
        <div class="device" data-reveal style={`--reveal-delay:${i * 60}ms`}>
          <span class="device__icon"><Icon name={d.icon} size={26} /></span>
          <h3 class="device__name">{d.name}</h3>
          <p class="device__note">{d.note}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- ===================== FAQ ===================== -->
  <Section eyebrow="Questions" title="Frequently asked questions" centered>
    <Faq items={faqs} />
  </Section>
</BaseLayout>

<style>
  /* ---- Hero (full-bleed background image + dark scrim) ---- */
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: clamp(560px, 84vh, 760px);
    border-bottom: 1px solid var(--mu-line-soft);
    background-image:
      linear-gradient(90deg, rgba(18, 18, 20, 0.95) 0%, rgba(18, 18, 20, 0.74) 36%, rgba(18, 18, 20, 0.3) 62%, rgba(18, 18, 20, 0.52) 100%),
      linear-gradient(0deg, var(--mu-bg) 1%, rgba(18, 18, 20, 0) 30%),
      url('/images/hero-cropped.png');
    background-position: 0 0, 0 0, 64% 26%;
    background-repeat: no-repeat;
    background-size: auto, auto, cover;
  }
  .hero__inner { width: 100%; padding-block: clamp(3rem, 7vw, 5rem); }
  .hero__copy { max-width: 620px; }

  .hero__title {
    font-size: var(--mu-text-4xl);
    line-height: 1.06;
    margin-top: var(--mu-space-5);
    margin-bottom: var(--mu-space-5);
    overflow-wrap: break-word;
  }
  .hero__accent { color: var(--mu-bronze-soft); }

  .hero__lead {
    font-size: var(--mu-text-lg);
    color: var(--mu-fog);
    max-width: 52ch;
  }
  .hero__proof {
    display: grid;
    gap: var(--mu-space-3);
    margin-top: var(--mu-space-5);
  }
  .hero__proof li {
    display: flex;
    align-items: flex-start;
    gap: var(--mu-space-3);
    color: var(--mu-fog);
    font-size: var(--mu-text-sm);
    font-weight: var(--mu-weight-medium);
  }
  .hero__proof :global(svg) { color: var(--mu-bronze-soft); flex-shrink: 0; margin-top: 3px; }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--mu-space-4);
    margin-top: var(--mu-space-6);
  }
  .hero__signin {
    margin-top: var(--mu-space-4);
    color: var(--mu-mute);
    font-size: var(--mu-text-sm);
  }
  .hero__signin a { color: var(--mu-bronze-soft); font-weight: var(--mu-weight-bold); }

  @media (max-width: 760px) {
    .hero {
      align-items: flex-end;
      min-height: 90vh;
      background-image:
        linear-gradient(180deg, rgba(18, 18, 20, 0.3) 0%, rgba(18, 18, 20, 0.72) 52%, var(--mu-bg) 99%),
        url('/images/hero-cropped.png');
      background-position: 0 0, 60% 16%;
      background-size: auto, cover;
    }
    .hero__copy { max-width: 100%; }
  }

  /* ---- Pricing band ---- */
  .plan { padding-block: var(--mu-section-y); }
  .plan__card {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: var(--mu-space-8);
    align-items: center;
    padding: clamp(2rem, 4vw, 3.5rem);
    background:
      radial-gradient(90% 130% at 100% 0%, rgba(164, 97, 51, 0.16), transparent 55%),
      var(--mu-green);
    border: 1px solid var(--mu-green-line);
    border-radius: var(--mu-radius-lg);
  }
  .plan__title {
    margin-top: var(--mu-space-4);
    font-size: var(--mu-text-3xl);
    line-height: 1.18;
  }
  .plan__price { color: var(--mu-bronze-soft); }
  .plan__sub { margin-top: var(--mu-space-4); color: var(--mu-fog); max-width: 48ch; }
  .plan__actions { display: flex; flex-wrap: wrap; gap: var(--mu-space-4); margin-top: var(--mu-space-6); }

  .plan__features { display: grid; gap: var(--mu-space-4); }
  .plan__features li {
    display: flex;
    align-items: flex-start;
    gap: var(--mu-space-3);
    color: var(--mu-white);
    font-weight: var(--mu-weight-medium);
  }
  .plan__check {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 26px; height: 26px;
    margin-top: 1px;
    color: var(--mu-on-accent);
    background: var(--mu-bronze);
    border-radius: var(--mu-radius-pill);
  }

  /* ---- Devices ---- */
  .device-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--mu-space-5);
  }
  .device {
    text-align: center;
    padding: var(--mu-space-6) var(--mu-space-4);
    background: var(--mu-surface-2);
    border: 1px solid var(--mu-line-soft);
    border-radius: var(--mu-radius);
    transition: transform var(--mu-dur) var(--mu-ease), border-color var(--mu-dur) var(--mu-ease);
  }
  .device:hover { transform: translateY(-3px); border-color: var(--mu-line); }
  .device__icon {
    display: inline-grid;
    place-items: center;
    width: 56px; height: 56px;
    margin-bottom: var(--mu-space-4);
    color: var(--mu-bronze-soft);
    background: var(--mu-bronze-tint);
    border-radius: var(--mu-radius);
  }
  .device__name { font-size: var(--mu-text-lg); }
  .device__note { margin-top: var(--mu-space-1); color: var(--mu-mute); font-size: var(--mu-text-sm); }

  /* ---- Responsive (page-specific; shared grids live in global.css) ---- */
  @media (max-width: 1000px) {
    .device-grid { grid-template-columns: repeat(2, 1fr); }
    .plan__card { grid-template-columns: 1fr; gap: var(--mu-space-6); }
  }
</style>
