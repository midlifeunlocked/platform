---
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/Section.astro';
import LessonCard from '@components/LessonCard.astro';
import InstructorCard from '@components/InstructorCard.astro';
import Icon from '@components/Icon.astro';
import { lessons, getInstructor, getCourse, instructorNames, relatedLessons, toCardProps } from '@/data/catalog';

export function getStaticPaths() {
  return lessons.map((lesson) => ({ params: { slug: lesson.slug }, props: { lesson } }));
}

const { lesson } = Astro.props;
const lessonInstructors = lesson.instructorSlugs.map(getInstructor).filter(Boolean);
const instructor = lessonInstructors[0]; // primary, for the sidebar card
const credit = instructorNames(lesson.instructorSlugs);
const course = getCourse(lesson.courseSlug);
const related = relatedLessons(lesson, 3);

// Cloudflare Stream subdomain for the MU account. Videos are currently public
// (imported with requireSignedURLs:false), so every lesson with a streamId
// plays for everyone. Phase 5 flips premium to signed URLs and only embeds the
// player after `canAccessLesson(user.id, lesson.id)` returns true.
const STREAM_CUSTOMER = 'customer-9992c2z2az4qp4mm.cloudflarestream.com';
const isFree = lesson.access === 'free';
const playerSrc = lesson.streamId
  ? `https://${STREAM_CUSTOMER}/${lesson.streamId}/iframe?preload=metadata`
  : null;
---

<BaseLayout
  title={`${lesson.title} — Midlife Unlocked`}
  description={lesson.description}
  ogImage={lesson.thumbnail}
>
  <article>
    <!-- Player over a full-bleed backdrop of the lesson image -->
    <section class="player" style={`--lesson-bg: url('${lesson.thumbnail}')`}>
      <div class="player__bg" aria-hidden="true"></div>
      <div class="player__scrim" aria-hidden="true"></div>
      <div class="mu-container player__inner">
        <nav class="crumbs" aria-label="Breadcrumb">
          <a href="/categories">Catalogue</a>
          <span aria-hidden="true">/</span>
          <a href="/categories">{lesson.category}</a>
        </nav>

        <div class="stage" data-reveal>
          {playerSrc ? (
            <iframe
              class="stage__player"
              src={playerSrc}
              title={lesson.title}
              loading="lazy"
              allow="accelerometer; gyroscope; autoplay; encrypted-media; picture-in-picture;"
              allowfullscreen
            ></iframe>
          ) : (
            <div class="stage__soon">
              <img class="stage__img" src={lesson.thumbnail} alt="" width="1280" height="720" />
              <div class="stage__soon-overlay">
                <span class="stage__lockicon"><Icon name="play" size={22} /></span>
                <p class="stage__lockcopy">Video coming soon</p>
              </div>
            </div>
          )}
        </div>
      </div>
    </section>

    <!-- Detail -->
    <Section>
      <div class="detail">
        <div class="detail__main" data-reveal>
          <div class="detail__meta">
            <span class="detail__category">{lesson.category}</span>
            <span class:list={['detail__badge', isFree ? 'is-free' : 'is-premium']}>
              <Icon name={isFree ? 'unlock' : 'lock'} size={13} />
              {isFree ? 'Free' : 'Premium'}
            </span>
            {lesson.duration && <span class="detail__duration">{lesson.duration}</span>}
            {course && <span class="detail__duration">Part of {course.name}</span>}
          </div>
          <h1 class="detail__title">{lesson.title}</h1>
          {lesson.description && <p class="detail__desc">{lesson.description}</p>}
          {credit && <p class="detail__by">Taught by <span class="detail__credit">{credit}</span></p>}

          {/* Phase 5 reinstates the premium gate (lock + "Unlock with Premium")
              here, shown only when canAccessLesson() is false. */}

          {lesson.details && (
            <div class="detail__about">
              <h2 class="detail__about-title">About this masterclass</h2>
              <div class="rich" set:html={lesson.details} />
            </div>
          )}
        </div>

        {instructor && (
          <aside class="detail__side" data-reveal style="--reveal-delay:120ms">
            <InstructorCard
              name={instructor.name}
              role={instructor.role}
              photo={instructor.photo}
              specialties={instructor.specialties}
              href={`/instructors/${instructor.slug}`}
            />
          </aside>
        )}
      </div>
    </Section>

    <!-- Related -->
    <Section tone="inset" eyebrow="Keep going" title="More like this">
      <div class="lesson-grid">
        {related.map((l, i) => <LessonCard {...toCardProps(l)} data-reveal style={`--reveal-delay:${i * 80}ms`} />)}
      </div>
    </Section>
  </article>
</BaseLayout>

<style>
  .player {
    position: relative;
    overflow: hidden;
    padding-top: clamp(2.5rem, 9vw, 7rem);
    padding-bottom: var(--mu-space-7);
  }
  /* full-bleed cover image of the lesson behind the player */
  .player__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: var(--lesson-bg);
    background-size: cover;
    background-position: 50% 28%;
  }
  /* dark scrim: darker at top (crumbs) and bottom (fade to page), lighter mid */
  .player__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(
        to bottom,
        rgba(18, 18, 20, 0.85) 0%,
        rgba(18, 18, 20, 0.34) 22%,
        rgba(18, 18, 20, 0.34) 52%,
        var(--mu-bg) 99%
      );
  }
  .player__inner { position: relative; z-index: 2; }
  .crumbs {
    display: flex;
    gap: var(--mu-space-2);
    margin-bottom: var(--mu-space-5);
    color: var(--mu-mute);
    font-size: var(--mu-text-sm);
  }
  .crumbs a { color: var(--mu-mute); }
  .crumbs a:hover { color: var(--mu-bronze-soft); }

  .stage {
    position: relative;
    aspect-ratio: 16 / 9;
    border: 1px solid var(--mu-line);
    border-radius: var(--mu-radius-lg);
    overflow: hidden;
    background: #000;
    box-shadow: var(--mu-shadow-lg);
  }
  .stage__player { width: 100%; height: 100%; border: 0; display: block; }

  /* fallback for lessons whose video hasn't been ported yet */
  .stage__soon { position: absolute; inset: 0; }
  .stage__img { width: 100%; height: 100%; object-fit: cover; filter: brightness(0.4) saturate(0.8); }
  .stage__soon-overlay {
    position: absolute;
    inset: 0;
    display: grid;
    place-content: center;
    justify-items: center;
    gap: var(--mu-space-4);
    text-align: center;
    padding: var(--mu-space-5);
  }
  .stage__lockicon {
    display: grid;
    place-items: center;
    width: 56px; height: 56px;
    color: var(--mu-bronze-soft);
    background: var(--mu-bronze-tint);
    border-radius: var(--mu-radius-pill);
  }
  .stage__lockcopy { color: var(--mu-white); font-family: var(--mu-font-display); font-weight: var(--mu-weight-bold); font-size: var(--mu-text-lg); }

  .detail { display: grid; grid-template-columns: 1.6fr 1fr; gap: var(--mu-space-8); align-items: start; }
  .detail__meta { display: flex; flex-wrap: wrap; align-items: center; gap: var(--mu-space-3); }
  .detail__category { color: var(--mu-bronze-soft); font-size: var(--mu-text-xs); font-weight: var(--mu-weight-bold); letter-spacing: var(--mu-tracking-label); text-transform: uppercase; }
  .detail__badge {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 4px 10px; font-size: var(--mu-text-xs); font-weight: var(--mu-weight-bold);
    text-transform: uppercase; border-radius: var(--mu-radius-pill);
  }
  .detail__badge.is-free { color: var(--mu-on-accent); background: var(--mu-bronze); }
  .detail__badge.is-premium { color: var(--mu-fog); background: var(--mu-surface-3); border: 1px solid var(--mu-line); }
  .detail__duration { color: var(--mu-mute); font-size: var(--mu-text-sm); }
  .detail__title { margin-top: var(--mu-space-4); font-size: var(--mu-text-3xl); }
  .detail__desc { margin-top: var(--mu-space-4); font-size: var(--mu-text-lg); color: var(--mu-fog); max-width: 60ch; }
  .detail__by { margin-top: var(--mu-space-4); color: var(--mu-mute); }
  .detail__credit { color: var(--mu-bronze-soft); font-weight: var(--mu-weight-bold); }
  .detail__cta { display: flex; flex-wrap: wrap; gap: var(--mu-space-4); margin-top: var(--mu-space-6); }
  .detail__about { margin-top: var(--mu-space-7); padding-top: var(--mu-space-6); border-top: 1px solid var(--mu-line-soft); }
  .detail__about-title { font-size: var(--mu-text-xl); margin-bottom: var(--mu-space-5); }

  @media (max-width: 860px) {
    .detail { grid-template-columns: 1fr; gap: var(--mu-space-6); }
  }
</style>
