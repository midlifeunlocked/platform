---
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/Section.astro';
import LessonCard from '@components/LessonCard.astro';
import InstructorCard from '@components/InstructorCard.astro';
import Button from '@components/Button.astro';
import Carousel from '@components/Carousel.astro';
import Icon from '@components/Icon.astro';
import { lessons, getInstructor, getCourse, instructorNames, relatedLessons, lessonsByCourse, toCardProps } from '@/data/catalog';

export function getStaticPaths() {
  return lessons.map((lesson) => ({ params: { slug: lesson.slug }, props: { lesson } }));
}

const { lesson } = Astro.props;
const lessonInstructors = lesson.instructorSlugs
  .map(getInstructor)
  .filter((i): i is NonNullable<typeof i> => Boolean(i));
const credit = instructorNames(lesson.instructorSlugs);
const course = getCourse(lesson.courseSlug);
const courseSiblings = course ? lessonsByCourse(course.slug).filter((l) => l.slug !== lesson.slug) : [];
const related = relatedLessons(lesson, 3);
const bg = lesson.backdrop || lesson.thumbnail;

// Cloudflare Stream player. Opened in a lightbox (see <dialog> + script), not
// embedded inline — matching the original template. Videos are public for now;
// Phase 5 gates premium behind canAccessLesson() before the lightbox opens.
const STREAM_CUSTOMER = 'customer-9992c2z2az4qp4mm.cloudflarestream.com';
const isFree = lesson.access === 'free';
const playerSrc = lesson.streamId ? `https://${STREAM_CUSTOMER}/${lesson.streamId}/iframe?preload=metadata` : null;
---

<BaseLayout title={`${lesson.title} — Midlife Unlocked`} description={lesson.description} ogImage={lesson.thumbnail}>
  <article>
    <!-- HERO: featured image + title + watch button -->
    <section class="lhero" style={`--bg: url('${bg}')`}>
      <div class="lhero__bg" aria-hidden="true"></div>
      <div class="lhero__scrim" aria-hidden="true"></div>
      <div class="mu-container lhero__inner">
        <nav class="crumbs" aria-label="Breadcrumb">
          <a href="/categories">Catalogue</a>
          <span aria-hidden="true">/</span>
          <a href="/categories">{lesson.category}</a>
        </nav>

        <div class="lhero__meta" data-reveal>
          <span class:list={['lhero__badge', isFree ? 'is-free' : 'is-premium']}>
            <Icon name={isFree ? 'unlock' : 'lock'} size={13} />{isFree ? 'Free' : 'Premium'}
          </span>
          <span class="lhero__cat">{lesson.category}</span>
          {lesson.duration && <span class="lhero__dot">{lesson.duration}</span>}
          {course && <span class="lhero__dot">Part of {course.name}</span>}
        </div>

        <h1 class="lhero__title" data-reveal style="--reveal-delay:70ms">{lesson.title}</h1>
        {lesson.description && <p class="lhero__desc" data-reveal style="--reveal-delay:140ms">{lesson.description}</p>}
        {credit && <p class="lhero__by" data-reveal style="--reveal-delay:200ms">Taught by <span>{credit}</span></p>}

        <div class="lhero__actions" data-reveal style="--reveal-delay:260ms">
          {playerSrc ? (
            <Button data-watch size="lg" icon="play">Watch now</Button>
          ) : (
            <span class="lhero__soon"><Icon name="lock" size={16} /> Video coming soon</span>
          )}
        </div>
      </div>
    </section>

    <!-- CONTENT: overview + info sidebar -->
    <Section>
      <div class="detail">
        <div class="detail__main" data-reveal>
          {lesson.details ? (
            <>
              <h2 class="detail__h">About this masterclass</h2>
              <div class="rich" set:html={lesson.details} />
            </>
          ) : (
            <p class="detail__lead">{lesson.description}</p>
          )}
        </div>

        <aside class="detail__side" data-reveal style="--reveal-delay:120ms">
          <div class="info">
            <h3 class="info__h">Details</h3>
            <dl class="info__list">
              <div><dt>Category</dt><dd>{lesson.category}</dd></div>
              {lesson.duration && <div><dt>Length</dt><dd>{lesson.duration}</dd></div>}
              {course && <div><dt>Course</dt><dd>{course.name}</dd></div>}
              <div><dt>Access</dt><dd>{isFree ? 'Free' : 'Premium'}</dd></div>
            </dl>
          </div>
          {lessonInstructors.length > 0 && (
            <div class="detail__instructors">
              {lessonInstructors.map((ins) => (
                <InstructorCard
                  name={ins.name}
                  role={ins.role}
                  photo={ins.photo}
                  specialties={ins.specialties}
                  href={`/instructors/${ins.slug}`}
                />
              ))}
            </div>
          )}
        </aside>
      </div>
    </Section>

    <!-- COURSE SIBLINGS -->
    {course && courseSiblings.length > 0 && (
      <Section eyebrow="Course" title={`More from ${course.name}`}>
        <Carousel variant="lessons" label={course.name} data-reveal>
          {courseSiblings.map((l) => <LessonCard {...toCardProps(l)} />)}
        </Carousel>
      </Section>
    )}

    <!-- RELATED -->
    <Section tone="inset" eyebrow="Keep going" title="More like this">
      <div class="lesson-grid">
        {related.map((l, i) => <LessonCard {...toCardProps(l)} data-reveal style={`--reveal-delay:${i * 80}ms`} />)}
      </div>
    </Section>
  </article>

  {playerSrc && (
    <dialog class="lightbox" data-lightbox aria-label={`${lesson.title} video`}>
      <div class="lightbox__inner">
        <button class="lightbox__close" data-close aria-label="Close video"><Icon name="close" size={22} /></button>
        <div class="lightbox__frame">
          <iframe data-frame title={lesson.title} allow="accelerometer; gyroscope; autoplay; encrypted-media; picture-in-picture;" allowfullscreen></iframe>
        </div>
      </div>
    </dialog>
  )}
</BaseLayout>

<script define:vars={{ src: playerSrc }}>
  if (src) {
    const dlg = document.querySelector('[data-lightbox]');
    const frame = dlg.querySelector('[data-frame]');
    const open = () => { frame.src = `${src}&autoplay=true`; dlg.showModal(); };
    const close = () => dlg.close();
    document.querySelectorAll('[data-watch]').forEach((b) => b.addEventListener('click', open));
    dlg.querySelector('[data-close]').addEventListener('click', close);
    dlg.addEventListener('close', () => { frame.src = ''; }); // stop playback on close
    dlg.addEventListener('click', (e) => { if (e.target === dlg) close(); }); // click backdrop
  }
</script>

<style>
  /* ---- Hero ---- */
  .lhero {
    position: relative;
    display: flex;
    align-items: flex-end;
    min-height: clamp(540px, 82vh, 820px);
    margin-top: -72px;          /* slide under the sticky nav */
    padding-top: 72px;
    overflow: hidden;
  }
  .lhero__bg {
    position: absolute; inset: 0; z-index: 0;
    background-image: var(--bg);
    background-size: cover;
    background-position: 50% 30%;
  }
  .lhero__scrim {
    position: absolute; inset: 0; z-index: 1;
    background:
      linear-gradient(to top, var(--mu-bg) 2%, rgba(18,18,20,0.86) 26%, rgba(18,18,20,0.32) 62%, rgba(18,18,20,0.55) 100%);
  }
  .lhero__inner { position: relative; z-index: 2; width: 100%; padding-block: var(--mu-space-7) var(--mu-space-8); }

  .crumbs { display: flex; gap: var(--mu-space-2); margin-bottom: var(--mu-space-5); color: var(--mu-mute); font-size: var(--mu-text-sm); }
  .crumbs a { color: var(--mu-fog); }
  .crumbs a:hover { color: var(--mu-bronze-soft); }

  .lhero__meta { display: flex; flex-wrap: wrap; align-items: center; gap: var(--mu-space-3); margin-bottom: var(--mu-space-4); }
  .lhero__badge {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 4px 11px; font-size: var(--mu-text-xs); font-weight: var(--mu-weight-bold);
    text-transform: uppercase; letter-spacing: 0.04em; border-radius: var(--mu-radius-pill);
  }
  .lhero__badge.is-free { color: var(--mu-on-accent); background: var(--mu-bronze); }
  .lhero__badge.is-premium { color: var(--mu-fog); background: rgba(18,18,20,0.6); border: 1px solid var(--mu-line); }
  .lhero__cat { color: var(--mu-bronze-soft); font-size: var(--mu-text-xs); font-weight: var(--mu-weight-bold); letter-spacing: var(--mu-tracking-label); text-transform: uppercase; }
  .lhero__dot { color: var(--mu-mute); font-size: var(--mu-text-sm); }
  .lhero__dot::before { content: '·'; margin-right: var(--mu-space-3); color: var(--mu-faint); }

  .lhero__title { font-size: var(--mu-text-4xl); max-width: 18ch; }
  .lhero__desc { margin-top: var(--mu-space-4); font-size: var(--mu-text-lg); color: var(--mu-fog); max-width: 56ch; }
  .lhero__by { margin-top: var(--mu-space-3); color: var(--mu-mute); }
  .lhero__by span { color: var(--mu-bronze-soft); font-weight: var(--mu-weight-bold); }
  .lhero__actions { margin-top: var(--mu-space-6); }
  .lhero__soon { display: inline-flex; align-items: center; gap: var(--mu-space-2); color: var(--mu-mute); font-weight: var(--mu-weight-bold); }

  /* ---- Content ---- */
  .detail { display: grid; grid-template-columns: 1.6fr 1fr; gap: var(--mu-space-8); align-items: start; }
  .detail__instructors { display: grid; gap: var(--mu-space-4); }
  .detail__h { font-size: var(--mu-text-xl); margin-bottom: var(--mu-space-5); }
  .detail__lead { font-size: var(--mu-text-lg); color: var(--mu-fog); }

  .info {
    padding: var(--mu-space-6);
    margin-bottom: var(--mu-space-5);
    background: var(--mu-surface-2);
    border: 1px solid var(--mu-line-soft);
    border-radius: var(--mu-radius-lg);
  }
  .info__h { font-size: var(--mu-text-lg); margin-bottom: var(--mu-space-4); }
  .info__list { display: grid; gap: var(--mu-space-4); }
  .info__list div { display: flex; justify-content: space-between; gap: var(--mu-space-4); border-bottom: 1px solid var(--mu-line-soft); padding-bottom: var(--mu-space-3); }
  .info__list div:last-child { border-bottom: 0; padding-bottom: 0; }
  .info__list dt { color: var(--mu-mute); font-size: var(--mu-text-sm); }
  .info__list dd { color: var(--mu-white); font-weight: var(--mu-weight-bold); font-size: var(--mu-text-sm); text-align: right; }

  /* ---- Lightbox ---- */
  .lightbox {
    width: 100vw; max-width: 100vw; height: 100dvh; max-height: 100dvh;
    margin: 0; padding: var(--mu-gutter); border: 0; background: transparent;
    place-items: center;
  }
  .lightbox[open] { display: grid; }
  .lightbox::backdrop { background: rgba(0,0,0,0.88); backdrop-filter: blur(4px); }
  .lightbox__inner { position: relative; width: min(1120px, 100%); }
  .lightbox__frame { aspect-ratio: 16/9; border-radius: var(--mu-radius-lg); overflow: hidden; box-shadow: var(--mu-shadow-lg); background: #000; }
  .lightbox__frame iframe { width: 100%; height: 100%; border: 0; display: block; }
  .lightbox__close {
    position: absolute; top: -52px; right: 0;
    display: grid; place-items: center; width: 40px; height: 40px;
    color: var(--mu-white); background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2); border-radius: var(--mu-radius-pill); cursor: pointer;
    transition: background-color var(--mu-dur) var(--mu-ease);
  }
  .lightbox__close:hover { background: rgba(255,255,255,0.2); }

  @media (max-width: 860px) {
    .detail { grid-template-columns: 1fr; gap: var(--mu-space-6); }
    .lhero { min-height: 78vh; }
  }
</style>
