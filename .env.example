# Midlife Unlocked — environment contract. Copy to `.env` and fill with real
# values. NEVER commit `.env`; NEVER paste secret keys into chat or the repo.
# Public (PUBLIC_*) vars are exposed to the browser; everything else is server-only
# (used by the owned webhook Worker and server endpoints).

# ── Supabase ──────────────────────────────────────────────────────────────────
# From Supabase dashboard → Project Settings → API.
PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key            # safe in the browser; RLS enforces access
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key          # SERVER ONLY — bypasses RLS. Never ships to client.

# ── Stripe (USA, test mode first) ─────────────────────────────────────────────
# From Stripe dashboard → Developers → API keys (toggle Test mode).
STRIPE_SECRET_KEY=sk_test_xxx                            # SERVER ONLY
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx                # safe in the browser
STRIPE_WEBHOOK_SECRET=whsec_xxx                          # from the webhook endpoint / `stripe listen`

# ── Email (Loops — added at the email step) ───────────────────────────────────
# LOOPS_API_KEY=
